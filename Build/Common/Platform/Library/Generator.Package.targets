<Project>
  <!-- ソースジェネレーターを内部に埋め込んだライブラリの設定（NuGetに直接公開） -->

  <PropertyGroup>
    <_GeneratorInternalProjectName>$(MSBuildProjectName).Internal</_GeneratorInternalProjectName>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>

    <!-- パッケージ分析を無効にする。 -->
    <NoPackageAnalysis>true</NoPackageAnalysis>

    <!-- ルート名前空間を、プロジェクト名末尾から「Generator」を取り除いたものにする。 -->
    <RootNamespace>$(MSBuildProjectName.Substring(0, $(MSBuildProjectName.LastIndexOf('.'))))</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Internalプロジェクトより後にビルドさせるため、プロジェクト参照を設定する。
      ReferenceOutputAssemblyをfalseに設定することで、アセンブリが出力対象外となる。
    -->
    <ProjectReference Include="../$(_GeneratorInternalProjectName)/$(_GeneratorInternalProjectName).csproj" ReferenceOutputAssembly="false" />

    <!-- パッケージ内部にソースジェネレーターのdllを埋め込む。 -->
    <None Include="$(ArtifactsPath)/bin/$(_GeneratorInternalProjectName)/$(Configuration.ToLowerInvariant())/$(_GeneratorInternalProjectName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />

    <!-- FToolkit.AnalyzerUtilitiesのdllを埋め込む。 -->
    <None Include="$(PkgFToolkit_AnalyzerUtilities)/lib/net10.0/*.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <!-- パッケージ内部にロジック本体のdllを埋め込む。 -->
  <ItemGroup Condition="Exists('$(MainLogicProjectPath)')">
    <None Condition="Exists('$(MainLogicAssemblyPath)')" Include="$(MainLogicAssemblyPath)" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Condition="!Exists('$(MainLogicAssemblyPath)')" Include="$(MainLogicAssemblyPathWithTargetFramework)" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <Import Project="$(BuildCommonAnalyzersDirectory)Analyzers.Trimming.targets" />
  <Import Project="$(BuildCommonPackDirectory)NuGet.targets" />
  <Import Project="$(BuildCommonPackDirectory)SourceLink.targets" />

</Project>
