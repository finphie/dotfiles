<Project>
  <!-- ソースジェネレーター本体の設定（NuGetには直接公開しない） -->

  <PropertyGroup>
    <!-- nullチェックは不要。 -->
    <NoWarn>$(NoWarn);CA1062</NoWarn>

    <!-- Roslynコンポーネントとして扱う。 -->
    <IsRoslynComponent>true</IsRoslynComponent>

    <!-- 一部のAPIを使用禁止にする。 -->
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>

    <!-- _GetDependencyTargetPathsターゲットを読み込む。 -->
    <GetTargetPathDependsOn>$(GetTargetPathDependsOn);_GetDependencyTargetPaths</GetTargetPathDependsOn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <!-- ロジック本体プロジェクトが存在する場合、プロジェクト参照を設定する。 -->
    <ProjectReference Condition="Exists('$(MainLogicProjectPath)')" Include="$(MainLogicProjectPath)" />
  </ItemGroup>

  <Import Project="$(MSBuildThisFileDirectory)Internal.targets" />

  <!--
    ソースジェネレーターをプロジェクト参照するプロジェクトで、必要なdllを読み込む。
    この設定がない場合、FileNotFoundExceptionが発生する。
  -->
  <Target Name="_GetDependencyTargetPaths">
    <ItemGroup>
      <!-- FToolkit.AnalyzerUtilitiesへの依存関係を設定する。 -->
      <TargetPathWithTargetPlatformMoniker Include="$(PkgFToolkit_AnalyzerUtilities)/lib/net10.0/*.dll" IncludeRuntimeDependency="false" />
    </ItemGroup>

    <!-- ロジック本体プロジェクトへの依存関係を設定する。 -->
    <ItemGroup Condition="Exists('$(MainLogicProjectPath)')">
      <TargetPathWithTargetPlatformMoniker Condition="Exists('$(MainLogicAssemblyPath)')" Include="$(MainLogicAssemblyPath)" IncludeRuntimeDependency="false" />
      <TargetPathWithTargetPlatformMoniker Condition="!Exists('$(MainLogicAssemblyPath)')" Include="$(MainLogicAssemblyPathWithTargetFramework)" IncludeRuntimeDependency="false" />
    </ItemGroup>
  </Target>

</Project>
